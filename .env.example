# ──────────────────────────────────────────────────────────────
# El Pitazo — environment variables template
# Copy to .env.local for local dev, then fill in secrets.
# ──────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_NAME="El Pitazo"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# ── Database (Neon) ────────────────────────────────────────────
# Get from: https://console.neon.tech → Project → Connection string
# Use the pgbouncer URL for production (adds ?pgbouncer=true&connection_limit=1)
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require"

# ── NextAuth ───────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Legacy JWT secret (used by getUserId helper)
JWT_SECRET="el-pitazo-secret-change-in-production"

# ── Google OAuth ───────────────────────────────────────────────
# console.cloud.google.com → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Apple OAuth ────────────────────────────────────────────────
# developer.apple.com → Certificates → Services IDs
# APPLE_SECRET is a signed JWT — see NextAuth Apple provider docs
APPLE_ID=""
APPLE_SECRET=""

# ── MercadoPago ────────────────────────────────────────────────
# mercadopago.com.mx → Developers → Credentials
MP_PUBLIC_KEY=""
MP_SECRET_KEY=""
MP_WEBHOOK_SECRET=""
NEXT_PUBLIC_MP_PUBLIC_KEY=""

# ── Stripe (optional / future) ────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── Vercel Blob ────────────────────────────────────────────────
# vercel.com/storage/blob → create store → copy token
BLOB_READ_WRITE_TOKEN=

# ── Web Push (VAPID) ───────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:admin@elpitazo.app
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── Google Maps ────────────────────────────────────────────────
# console.cloud.google.com → Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# ── Apple Wallet passes ────────────────────────────────────────
# developer.apple.com → Certificates → Pass Type IDs
# APPLE_WWDR_CERT: Download from apple.com/certificateauthority/AppleWWDRCAG4.cer (convert to PEM)
# APPLE_PASS_CERT: Your Pass Type Certificate (PEM format)
# APPLE_PASS_KEY:  Your private key (PEM format)
APPLE_PASS_TYPE_IDENTIFIER="pass.com.elpitazo.player"
APPLE_TEAM_IDENTIFIER=""
APPLE_WWDR_CERT=""
APPLE_PASS_CERT=""
APPLE_PASS_KEY=""
APPLE_PASS_KEY_PASSPHRASE=""

# ── Sentry ─────────────────────────────────────────────────────
# sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ── Redis (optional — for rate-limiting / caching) ─────────────
REDIS_URL=""

# ── SMS / Twilio (optional) ────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ── AWS S3 (optional — alternative media storage) ─────────────
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
