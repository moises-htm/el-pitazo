# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/el_pitazo?sslmode=disable"

# JWT
JWT_SECRET="el-pitazo-secret-change-in-production"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# MercadoPago
MP_PUBLIC_KEY=""
MP_SECRET_KEY=""
MP_WEBHOOK_SECRET=""

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="El Pitazo"

# AWS S3 (for media storage)
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# Redis
REDIS_URL=""

# SMS (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# NextAuth
NEXTAUTH_URL="https://el-pitazo.vercel.app"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (console.cloud.google.com → Credentials → OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple OAuth (developer.apple.com → Certificates → Services IDs)
# APPLE_SECRET is a JWT — generate with next-auth Apple provider documentation
APPLE_ID=""
APPLE_SECRET=""

# Google Maps (console.cloud.google.com → Maps Static API)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# Apple Wallet passes (developer.apple.com → Certificates → Pass Type IDs)
# APPLE_WWDR_CERT: Download from https://www.apple.com/certificateauthority/AppleWWDRCAG4.cer (convert to PEM)
# APPLE_PASS_CERT: Your Pass Type Certificate (PEM format)
# APPLE_PASS_KEY: Your private key (PEM format)
APPLE_PASS_TYPE_IDENTIFIER="pass.com.elpitazo.player"
APPLE_TEAM_IDENTIFIER=""
APPLE_WWDR_CERT=""
APPLE_PASS_CERT=""
APPLE_PASS_KEY=""
APPLE_PASS_KEY_PASSPHRASE=""

# Web Push (VAPID) — run `npx web-push generate-vapid-keys` to generate
VAPID_SUBJECT=mailto:admin@elpitazo.app
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
