generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLAYER
  REFEREE
  ORGANIZER
}

enum TournamentStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  POSTPONED
  CANCELLED
}

enum BracketType {
  LEAGUE
  KNOCKOUT
  GROUPS
  SWISS
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

enum PaymentMethod {
  STRIPE
  MERCADOPAGO
  SPEI
  OXXO
  CASH
}

enum TeamPaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  phone     String?  @unique
  email     String?  @unique
  password  String
  role      Role[]
  name      String
  avatar    String?
  country   String   @default("MX")
  lang      String   @default("es")
  rating    Decimal  @default(0.00)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdTournaments   Tournament[]              @relation("TournamentCreator")
  refereeAssignments   RefereeAssignment[]
  refereeReports       RefereeReport[]
  notifications        Notification[]              @relation("UserNotifications")
  payments             Payment[]
  teamMembers          TeamMember[]
  teamCaptain          Team?                         @relation("TeamCaptains")
  refereeMatches       BracketMatch[]                @relation("MatchReferee")
  tournamentMedia      TournamentMedia[]               @relation("MediaUploaders")
  events               MatchEvent[]

  @@map("users")
}

model Tournament {
  id             String              @id @default(uuid()) @db.Uuid
  creatorId      String              @db.Uuid
  creator        User                @relation("TournamentCreator", fields: [creatorId], references: [id])
  name           String
  description    String?
  type           BracketType
  maxTeams       Int
  status         TournamentStatus    @default(DRAFT)
  startDate      DateTime?
  endDate        DateTime?
  fieldLocation  String?
  fieldAddress   String?
  fieldLat       Decimal?
  fieldLng       Decimal?
  rules          Json?
  regFee         Decimal
  currency       String              @default("MXN")
  websiteUrl     String?
  coverImage     String?
  isPublic       Boolean             @default(true)
  minSkill       Int?
  maxSkill       Int?
  photoCount     Int                 @default(0)
  totalScoreCount Int                @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  fields         Field[]
  teams          Team[]
  bracketRounds  BracketRound[]
  notifications  Notification[]        @relation("TournamentNotifications")
  payments       Payment[]
  media          TournamentMedia[]      @relation("TournamentMedia")
  sponsors       Sponsor[]
  analytics      TournamentAnalytics[]

  @@map("tournaments")
}

model Field {
  id            String   @id @default(uuid()) @db.Uuid
  tournamentId  String   @db.Uuid
  tournament    Tournament @relation(fields: [tournamentId], references: [id])
  name          String
  address       String?
  lat           Decimal?
  lng           Decimal?
  surface       String?
  size          String?
  availableSlots Json?
  aedAvailable  Boolean  @default(false)
  aedLocation   String?
  waterAvail    Boolean  @default(false)
  parkingAvail  Boolean  @default(false)
  createdAt     DateTime @default(now())

  matches       BracketMatch[]

  @@map("fields")
}

model Team {
  id             String              @id @default(uuid()) @db.Uuid
  tournamentId   String              @db.Uuid
  tournament     Tournament          @relation(fields: [tournamentId], references: [id])
  name           String
  captainId      String?             @unique @db.Uuid
  captain        User?               @relation("TeamCaptains", fields: [captainId], references: [id])
  logo           String?
  colorHex       String?
  skillLevel     Int?
  payStatus      TeamPaymentStatus   @default(PENDING)
  payAmount      Decimal
  playersCount   Int                 @default(0)
  createdAt      DateTime            @default(now())

  members        TeamMember[]
  homeMatches    BracketMatch[]      @relation("HomeMatches")
  awayMatches    BracketMatch[]      @relation("AwayMatches")
  payments       Payment[]

  @@unique([tournamentId, name])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String              @db.Uuid
  team      Team     @relation(fields: [teamId], references: [id])
  userId    String              @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  number    Int
  position  String?
  isCaptain Boolean  @default(false)
  joinedAt  DateTime @default(now())

  @@unique([teamId, number])
  @@unique([teamId, userId])
  @@map("team_members")
}

model BracketRound {
  id         String            @id @default(uuid()) @db.Uuid
  tournamentId String          @db.Uuid
  tournament Tournament        @relation(fields: [tournamentId], references: [id])
  roundNum   Int
  bracketType String?
  createdAt  DateTime          @default(now())

  matches    BracketMatch[]

  @@unique([tournamentId, roundNum])
  @@map("bracket_rounds")
}

model BracketMatch {
  id              String         @id @default(uuid()) @db.Uuid
  roundId         String         @db.Uuid
  round           BracketRound   @relation(fields: [roundId], references: [id])
  fieldId         String?         @db.Uuid
  field           Field?         @relation(fields: [fieldId], references: [id])
  homeTeamId      String?         @db.Uuid
  homeTeam        Team?          @relation("HomeMatches", fields: [homeTeamId], references: [id])
  awayTeamId      String?         @db.Uuid
  awayTeam        Team?          @relation("AwayMatches", fields: [awayTeamId], references: [id])
  homeScore       Int?
  awayScore       Int?
  scheduledAt     DateTime?
  startedAt       DateTime?
  finishedAt      DateTime?
  refereeId       String?         @db.Uuid
  referee         User?          @relation("MatchReferee", fields: [refereeId], references: [id])
  status          MatchStatus    @default(SCHEDULED)
  forfeitTeamId   String?
  notes           String?
  homeConfirmed   Boolean        @default(false)
  awayConfirmed   Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  events          MatchEvent[]
  refereeAssign   RefereeAssignment?  @relation("MatchRefAssignment")
  reports         RefereeReport[]
  media           TournamentMedia[]    @relation("MatchMedia")

  @@map("bracket_matches")
}

model MatchEvent {
  id        String   @id @default(uuid()) @db.Uuid
  matchId   String   @db.Uuid
  match     BracketMatch @relation(fields: [matchId], references: [id])
  playerId  String?  @db.Uuid
  player    User?    @relation(fields: [playerId], references: [id])
  teamId    String?  @db.Uuid
  eventType String
  minute    Int
  extraMin  Int      @default(0)
  details   Json?
  createdAt DateTime @default(now())

  @@index([matchId])
  @@index([playerId])
  @@map("match_events")
}

model Payment {
  id                    String          @id @default(uuid()) @db.Uuid
  tournamentId          String?         @db.Uuid
  tournament            Tournament?     @relation(fields: [tournamentId], references: [id])
  teamId                String?         @db.Uuid
  team                  Team?           @relation(fields: [teamId], references: [id])
  userId                String          @db.Uuid
  user                  User            @relation(fields: [userId], references: [id])
  amount                Decimal
  currency              String          @default("MXN")
  method                PaymentMethod
  status                PaymentStatus   @default(PENDING)
  externalId            String?
  receiptUrl            String?
  paidAt                DateTime?
  createdAt             DateTime        @default(now())

  @@index([teamId])
  @@index([status])
  @@map("payments")
}

model RefereeAssignment {
  id          String      @id @default(uuid()) @db.Uuid
  matchId     String      @unique @db.Uuid
  match       BracketMatch @relation("MatchRefAssignment", fields: [matchId], references: [id])
  refereeId   String      @db.Uuid
  referee     User       @relation(fields: [refereeId], references: [id])
  secondRef   String?
  thirdRef    String?
  status      String      @default("assigned")
  fee         Decimal?
  paid        Boolean     @default(false)
  paidAt      DateTime?
  createdAt   DateTime    @default(now())

  @@unique([matchId, refereeId])
  @@index([refereeId])
  @@map("referee_assignments")
}

model RefereeReport {
  id             String     @id @default(uuid()) @db.Uuid
  matchId        String     @db.Uuid
  match          BracketMatch @relation(fields: [matchId], references: [id])
  refereeId      String     @db.Uuid
  referee        User       @relation(fields: [refereeId], references: [id])
  reportText     String?
  incidents      Json?
  fieldCond      String?
  safetyIssues   Json?
  captainSig     String?
  submittedAt    DateTime?
  createdAt      DateTime   @default(now())

  @@map("referee_reports")
}

model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  user       User     @relation("UserNotifications", fields: [userId], references: [id])
  tournamentId String? @db.Uuid
  tournament Tournament?  @relation("TournamentNotifications", fields: [tournamentId], references: [id])
  type       String
  title      String
  body       String
  data       Json?
  read       Boolean  @default(false)
  channel    String?
  sentAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, read])
  @@map("notifications")
}

model TournamentMedia {
  id          String   @id @default(uuid()) @db.Uuid
  tournamentId String  @db.Uuid
  tournament  Tournament  @relation("TournamentMedia", fields: [tournamentId], references: [id])
  matchId     String?  @db.Uuid
  match       BracketMatch? @relation("MatchMedia", fields: [matchId], references: [id])
  uploaderId  String   @db.Uuid
  uploader    User     @relation("MediaUploaders", fields: [uploaderId], references: [id])
  url         String
  type        String
  caption     String?
  createdAt   DateTime @default(now())

  @@index([tournamentId])
  @@map("tournament_media")
}

model Sponsor {
  id          String   @id @default(uuid()) @db.Uuid
  tournamentId String  @db.Uuid
  tournament  Tournament @relation(fields: [tournamentId], references: [id])
  name        String
  logo        String?
  tier        String
  amount      Decimal
  adPlacement Json?
  contact     String?
  createdAt   DateTime @default(now())

  @@map("sponsors")
}

model TournamentAnalytics {
  id          String   @id @default(uuid()) @db.Uuid
  tournamentId String  @db.Uuid
  tournament  Tournament @relation(fields: [tournamentId], references: [id])
  date        DateTime
  visitors    Int
  pageViews   Int
  regCount    Int
  payCount    Int
  payTotal    Decimal
  socialShares Int
  createdAt   DateTime @default(now())

  @@index([tournamentId])
  @@map("tournament_analytics")
}
