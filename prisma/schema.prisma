generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLAYER
  REFEREE
  ORGANIZER
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum TournamentStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  POSTPONED
  CANCELLED
}

enum BracketType {
  LEAGUE
  KNOCKOUT
  GROUPS
  SWISS
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

enum PaymentMethod {
  STRIPE
  MERCADOPAGO
  SPEI
  OXXO
  CASH
}

enum TeamPaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  phone     String?  @unique
  email     String?  @unique
  password  String?
  role      Role[]
  name      String
  avatar    String?
  country   String   @default("MX")
  lang      String   @default("es")
  rating    Decimal  @default(0.00)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  createdTournaments   Tournament[]              @relation("TournamentCreator")
  refereeAssignments   RefereeAssignment[]
  refereeReports       RefereeReport[]
  notifications        Notification[]              @relation("UserNotifications")
  payments             Payment[]
  teamMembers          TeamMember[]
  teamCaptain          Team?                         @relation("TeamCaptains")
  refereeMatches       BracketMatch[]                @relation("MatchReferee")
  tournamentMedia      TournamentMedia[]               @relation("MediaUploaders")
  events               MatchEvent[]
  feedPosts            FeedPost[]    @relation("FeedUploads")
  createdOrgs          Organization[]              @relation("OrgCreator")
  orgMemberships       OrganizationMember[]        @relation("OrgMembers")

  @@map("users")
}

model Tournament {
  id             String              @id @default(uuid()) @db.Uuid
  creatorId      String              @db.Uuid
  creator        User                @relation("TournamentCreator", fields: [creatorId], references: [id])
  organizationId String?             @db.Uuid
  organization   Organization?       @relation(fields: [organizationId], references: [id])
  name           String
  description    String?
  type           BracketType
  maxTeams       Int
  status         TournamentStatus    @default(DRAFT)
  startDate      DateTime?
  endDate        DateTime?
  fieldLocation  String?
  fieldAddress   String?
  fieldLat       Decimal?
  fieldLng       Decimal?
  rules          Json?
  regFee         Decimal
  currency       String              @default("MXN")
  websiteUrl     String?
  coverImage     String?
  isPublic       Boolean             @default(true)
  minSkill       Int?
  maxSkill       Int?
  photoCount     Int                 @default(0)
  totalScoreCount Int                @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  fields         Field[]
  teams          Team[]
  bracketRounds  BracketRound[]
  notifications  Notification[]        @relation("TournamentNotifications")
  payments       Payment[]
  media          TournamentMedia[]      @relation("TournamentMedia")
  sponsors       Sponsor[]
  analytics      TournamentAnalytics[]

  @@map("tournaments")
}

model Field {
  id            String   @id @default(uuid()) @db.Uuid
  tournamentId  String   @db.Uuid
  tournament    Tournament @relation(fields: [tournamentId], references: [id])
  name          String
  address       String?
  lat           Decimal?
  lng           Decimal?
  surface       String?
  size          String?
  availableSlots Json?
  aedAvailable  Boolean  @default(false)
  aedLocation   String?
  waterAvail    Boolean  @default(false)
  parkingAvail  Boolean  @default(false)
  createdAt     DateTime @default(now())

  matches       BracketMatch[]

  @@map("fields")
}

model Team {
  id             String              @id @default(uuid()) @db.Uuid
  tournamentId   String              @db.Uuid
  tournament     Tournament          @relation(fields: [tournamentId], references: [id])
  name           String
  captainId      String?             @unique @db.Uuid
  captain        User?               @relation("TeamCaptains", fields: [captainId], references: [id])
  logo           String?
  colorHex       String?
  skillLevel     Int?
  payStatus      TeamPaymentStatus   @default(PENDING)
  payAmount      Decimal
  playersCount   Int                 @default(0)
  createdAt      DateTime            @default(now())

  members        TeamMember[]
  homeMatches    BracketMatch[]      @relation("HomeMatches")
  awayMatches    BracketMatch[]      @relation("AwayMatches")
  payments       Payment[]

  @@unique([tournamentId, name])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String              @db.Uuid
  team      Team     @relation(fields: [teamId], references: [id])
  userId    String              @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  number    Int
  position  String?
  isCaptain Boolean  @default(false)
  joinedAt  DateTime @default(now())

  @@unique([teamId, number])
  @@unique([teamId, userId])
  @@map("team_members")
}

model BracketRound {
  id         String            @id @default(uuid()) @db.Uuid
  tournamentId String          @db.Uuid
  tournament Tournament        @relation(fields: [tournamentId], references: [id])
  roundNum   Int
  bracketType String?
  createdAt  DateTime          @default(now())

  matches    BracketMatch[]

  @@unique([tournamentId, roundNum])
  @@map("bracket_rounds")
}

model BracketMatch {
  id              String         @id @default(uuid()) @db.Uuid
  roundId         String         @db.Uuid
  round           BracketRound   @relation(fields: [roundId], references: [id])
  fieldId         String?         @db.Uuid
  field           Field?         @relation(fields: [fieldId], references: [id])
  homeTeamId      String?         @db.Uuid
  homeTeam        Team?          @relation("HomeMatches", fields: [homeTeamId], references: [id])
  awayTeamId      String?         @db.Uuid
  awayTeam        Team?          @relation("AwayMatches", fields: [awayTeamId], references: [id])
  homeScore       Int?
  awayScore       Int?
  scheduledAt     DateTime?
  startedAt       DateTime?
  finishedAt      DateTime?
  refereeId       String?         @db.Uuid
  referee         User?          @relation("MatchReferee", fields: [refereeId], references: [id])
  status          MatchStatus    @default(SCHEDULED)
  forfeitTeamId   String?
  notes           String?
  homeConfirmed   Boolean        @default(false)
  awayConfirmed   Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  events          MatchEvent[]
  refereeAssign   RefereeAssignment?  @relation("MatchRefAssignment")
  reports         RefereeReport[]
  media           TournamentMedia[]    @relation("MatchMedia")
  scheduleChanges ScheduleChangeRequest[]

  @@map("bracket_matches")
}

model MatchEvent {
  id        String   @id @default(uuid()) @db.Uuid
  matchId   String   @db.Uuid
  match     BracketMatch @relation(fields: [matchId], references: [id])
  playerId  String?  @db.Uuid
  player    User?    @relation(fields: [playerId], references: [id])
  teamId    String?  @db.Uuid
  eventType String
  minute    Int
  extraMin  Int      @default(0)
  details   Json?
  createdAt DateTime @default(now())

  @@index([matchId])
  @@index([playerId])
  @@map("match_events")
}

model Payment {
  id                    String          @id @default(uuid()) @db.Uuid
  tournamentId          String?         @db.Uuid
  tournament            Tournament?     @relation(fields: [tournamentId], references: [id])
  teamId                String?         @db.Uuid
  team                  Team?           @relation(fields: [teamId], references: [id])
  userId                String          @db.Uuid
  user                  User            @relation(fields: [userId], references: [id])
  amount                Decimal
  currency              String          @default("MXN")
  method                PaymentMethod
  status                PaymentStatus   @default(PENDING)
  externalId            String?
  receiptUrl            String?
  paidAt                DateTime?
  createdAt             DateTime        @default(now())

  @@index([teamId])
  @@index([status])
  @@map("payments")
}

model RefereeAssignment {
  id          String      @id @default(uuid()) @db.Uuid
  matchId     String      @unique @db.Uuid
  match       BracketMatch @relation("MatchRefAssignment", fields: [matchId], references: [id])
  refereeId   String      @db.Uuid
  referee     User       @relation(fields: [refereeId], references: [id])
  secondRef   String?
  thirdRef    String?
  status      String      @default("assigned")
  fee         Decimal?
  paid        Boolean     @default(false)
  paidAt      DateTime?
  createdAt   DateTime    @default(now())

  @@unique([matchId, refereeId])
  @@index([refereeId])
  @@map("referee_assignments")
}

model RefereeReport {
  id             String     @id @default(uuid()) @db.Uuid
  matchId        String     @db.Uuid
  match          BracketMatch @relation(fields: [matchId], references: [id])
  refereeId      String     @db.Uuid
  referee        User       @relation(fields: [refereeId], references: [id])
  reportText     String?
  incidents      Json?
  fieldCond      String?
  safetyIssues   Json?
  captainSig     String?
  submittedAt    DateTime?
  createdAt      DateTime   @default(now())

  @@map("referee_reports")
}

model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  user       User     @relation("UserNotifications", fields: [userId], references: [id])
  tournamentId String? @db.Uuid
  tournament Tournament?  @relation("TournamentNotifications", fields: [tournamentId], references: [id])
  type       String
  title      String
  body       String
  data       Json?
  read       Boolean  @default(false)
  channel    String?
  sentAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, read])
  @@map("notifications")
}

model TournamentMedia {
  id          String   @id @default(uuid()) @db.Uuid
  tournamentId String  @db.Uuid
  tournament  Tournament  @relation("TournamentMedia", fields: [tournamentId], references: [id])
  matchId     String?  @db.Uuid
  match       BracketMatch? @relation("MatchMedia", fields: [matchId], references: [id])
  uploaderId  String   @db.Uuid
  uploader    User     @relation("MediaUploaders", fields: [uploaderId], references: [id])
  url         String
  type        String
  caption     String?
  createdAt   DateTime @default(now())

  @@index([tournamentId])
  @@map("tournament_media")
}

model Sponsor {
  id          String   @id @default(uuid()) @db.Uuid
  tournamentId String  @db.Uuid
  tournament  Tournament @relation(fields: [tournamentId], references: [id])
  name        String
  logo        String?
  tier        String
  amount      Decimal
  adPlacement Json?
  contact     String?
  createdAt   DateTime @default(now())

  @@map("sponsors")
}

model TournamentAnalytics {
  id          String   @id @default(uuid()) @db.Uuid
  tournamentId String  @db.Uuid
  tournament  Tournament @relation(fields: [tournamentId], references: [id])
  date        DateTime
  visitors    Int
  pageViews   Int
  regCount    Int
  payCount    Int
  payTotal    Decimal
  socialShares Int
  createdAt   DateTime @default(now())

  @@index([tournamentId])
  @@map("tournament_analytics")
}

enum ScheduleChangeStatus {
  PENDING
  APPROVED
  REJECTED_BY_CAPTAIN
  REJECTED_BY_REFEREE
  REJECTED_BY_ORGANIZER
}

model ScheduleChangeRequest {
  id               String                @id @default(uuid()) @db.Uuid
  matchId          String                @db.Uuid
  match            BracketMatch          @relation(fields: [matchId], references: [id])
  requestedById    String                @db.Uuid
  proposedTime     DateTime
  reason           String?
  status           ScheduleChangeStatus  @default(PENDING)
  captainBApproved Boolean               @default(false)
  refereeApproved  Boolean               @default(false)
  organizerApproved Boolean              @default(false)
  captainBNote     String?
  refereeNote      String?
  organizerNote    String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([matchId])
  @@map("schedule_change_requests")
}

model PushSubscription {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  endpoint   String   @unique
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

model NotificationPreference {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid
  newMessage      Boolean  @default(true)
  scheduleChange  Boolean  @default(true)
  matchReminder   Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("notification_preferences")
}

model FeedPost {
  id            String    @id @default(uuid()) @db.Uuid
  uploaderId    String    @db.Uuid
  uploader      User      @relation("FeedUploads", fields: [uploaderId], references: [id])
  videoUrl      String
  thumbnailUrl  String?
  caption       String?
  teamId        String?   @db.Uuid
  tournamentId  String?   @db.Uuid
  isFeatured    Boolean   @default(false)
  likesCount    Int       @default(0)
  commentsCount Int       @default(0)
  createdAt     DateTime  @default(now())

  likes         FeedLike[]
  comments      FeedComment[]

  @@index([createdAt])
  @@index([uploaderId])
  @@map("feed_posts")
}

model FeedLike {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @db.Uuid
  post      FeedPost @relation(fields: [postId], references: [id])
  userId    String   @db.Uuid
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@map("feed_likes")
}

model FeedComment {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @db.Uuid
  post      FeedPost @relation(fields: [postId], references: [id])
  userId    String   @db.Uuid
  userName  String
  body      String
  createdAt DateTime @default(now())

  @@index([postId])
  @@map("feed_comments")
}

model Organization {
  id          String               @id @default(uuid()) @db.Uuid
  name        String
  logo        String?
  createdById String               @db.Uuid
  createdBy   User                 @relation("OrgCreator", fields: [createdById], references: [id])
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  members     OrganizationMember[]
  tournaments Tournament[]

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String       @db.Uuid
  user           User         @relation("OrgMembers", fields: [userId], references: [id])
  role           OrgRole      @default(MEMBER)
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum ChatRoomType {
  LIGA
  CAPTAIN_DM
  TEAM
}

model ChatRoom {
  id           String       @id @default(uuid()) @db.Uuid
  type         ChatRoomType
  tournamentId String?      @db.Uuid
  teamId       String?      @db.Uuid
  name         String
  createdAt    DateTime     @default(now())

  messages     ChatMessage[]

  @@map("chat_rooms")
}

model ChatMessage {
  id         String    @id @default(uuid()) @db.Uuid
  roomId     String    @db.Uuid
  room       ChatRoom  @relation(fields: [roomId], references: [id])
  userId     String    @db.Uuid
  userName   String
  body       String
  createdAt  DateTime  @default(now())

  @@index([roomId, createdAt])
  @@map("chat_messages")
}
